#!/usr/bin/env mshell

def msg (str str --)
    message! level!
    @level "info" startsWith if
        "" level!
    end
    $"redo: {@level} {@message}" wle
    @level "error" startsWith if
        111 exit
    end
end

def printHelp ( -- )
    "Usage: redo.msh [TARGET]..." wl
    "Usage: redo.msh root <PROJECT_ROOT>" wl
    "Usage: redo.msh root list" wl
    "Usage: redo.msh root remove <PROJECT_ROOT>" wl
    "" wl
    "Options:" wl
    "  -h, --help   Show this help text" wl
    "" wl
    "Commands:" wl
    "  root         Register a project root in the SQLite database" wl
    "  root list    List registered project roots" wl
    "  root remove  Remove a registered project root" wl
end

def isHelpArg (str -- bool)
    arg!
    @arg "-h" = @arg "--help" = or
end

def candidateProjectRoots (str -- [str])
    dir!
    @dir dirname str parent!
    @dir toPath @parent toPath =
    if
        [] roots!
        @roots @dir append drop
        @roots
    else
        @parent candidateProjectRoots parents!
        [] roots!
        @roots @dir append drop
        @roots @parents extend
    end
end

def printCandidateProjectRoots ([str] int --)
    index! roots!
    @roots len 0 > if
        @roots 0 nth root!
        $"{@index}. {@root}" wl
        @roots 1: @index 1 + printCandidateProjectRoots
    end
end

def selectCandidateProjectRoot ([str] str int -- str bool)
    index! answer! roots!
    @roots len 0 = if
        "" false
    else
        @index str indexStr!
        @answer @indexStr = if
            @roots 0 nth true
        else
            @roots 1: @answer @index 1 + selectCandidateProjectRoot
        end
    end
end

def promptForProjectRoot ([str] -- str bool)
    roots!
    @roots 1 printCandidateProjectRoots
    @roots len str maxIndex!
    $"Do you want to set one of these directories as a project root directory (1-{@maxIndex}, blank cancels)? " prompt answer!
    @answer len 0 = if
        "" false
    else
        @roots @answer 1 selectCandidateProjectRoot foundRoot! root!
        @foundRoot if
            @root true
        else
            "Invalid selection." wle
            @roots promptForProjectRoot
        end
    end
end

def dbDataDir ( -- str)
    $LOCALAPPDATA?
    if
        $"{$LOCALAPPDATA}/redo-msh"
    else
        $XDG_DATA_HOME?
        if
            $"{$XDG_DATA_HOME}/redo-msh"
        else
            $"{$HOME}/.local/share/redo-msh"
        end
    end
end

def sqlQuote (str -- str)
    value!
    @value "'" "''" findReplace escaped!
    "'" @escaped + "'" +
end

def dbPath ( -- str)
    $REDO_DB
end

def sqlExec (str --)
    sql!
    ['sqlite3' '-batch' dbPath @sql] ? rc!
    @rc 0 != if
        "error" $"sqlite3 failed with exit code {@rc}" msg
    end
end

def sqlRead (str -- str)
    ['sqlite3' '-batch' '-noheader' dbPath] swap append oc;
end

def sqlLines (str -- [str])
    sqlRead out!
    @out trim trimmed!
    @trimmed len 0 = if
        []
    else
        @out lines
    end
end

def ensureDb ( --)
    "CREATE TABLE IF NOT EXISTS Schema (version TEXT NOT NULL PRIMARY KEY);" sqlExec
    "CREATE TABLE IF NOT EXISTS Files (base TEXT NOT NULL, name TEXT NOT NULL, type TEXT, md5 TEXT, uptodate TEXT, result TEXT, PRIMARY KEY (base, name));" sqlExec
    "CREATE TABLE IF NOT EXISTS Deps (base TEXT NOT NULL, target TEXT NOT NULL, source TEXT NOT NULL, kind TEXT NOT NULL, phase TEXT NOT NULL, PRIMARY KEY (base, target, source, kind, phase));" sqlExec
    "CREATE TABLE IF NOT EXISTS ProjectRoots (root TEXT NOT NULL PRIMARY KEY);" sqlExec
    "SELECT version FROM Schema LIMIT 1;" sqlRead trim schemaVersion!
    @schemaVersion len 0 = if
        "INSERT INTO Schema (version) VALUES ('1');" sqlExec
        "1" schemaVersion!
    end
    @schemaVersion "1" != if
        "error" $"Unsupported schema version '{@schemaVersion}' in {$REDO_DB}" msg
    end
end

def hasGitDir (str -- bool)
    dir!
    @dir toPath `.git` / isDir
end

def registeredProjectRoot (str -- bool)
    dir!
    @dir sqlQuote dirSql!
    $"SELECT COUNT(*) FROM ProjectRoots WHERE root = {@dirSql};" sqlRead trim count!
    @count "0" !=
end

def isProjectRoot (str -- bool)
    dir!
    @dir registeredProjectRoot
    @dir hasGitDir
    or
end

def findProjectRoot (str -- str bool)
    dir!
    @dir isProjectRoot
    if
        @dir true
    else
        @dir dirname parent!
        @dir toPath @parent toPath =
        if
            "" false
        else
            @parent findProjectRoot
        end
    end
end

def registerProjectRoot (str --)
    rawRoot!
    @rawRoot absPath root!
    @root isDir not if
        "error" $"Project root does not exist: {@root}" msg
    end
    @root sqlQuote rootSql!
    $"INSERT OR IGNORE INTO ProjectRoots (root) VALUES ({@rootSql});" sqlExec
    "info" $"registered project root {@root}" msg
end

def removeProjectRoot (str --)
    rawRoot!
    @rawRoot absPath root!
    @root sqlQuote rootSql!
    $"SELECT COUNT(*) FROM ProjectRoots WHERE root = {@rootSql};" sqlRead trim existingCount!
    @existingCount "0" = if
        "info" $"project root was not registered {@root}" msg
    else
        $"DELETE FROM ProjectRoots WHERE root = {@rootSql};" sqlExec
        "info" $"removed project root {@root}" msg
    end
end

def listProjectRoots ( -- )
    "SELECT root FROM ProjectRoots ORDER BY root;" sqlLines
    (wl) each
end

dbDataDir redoDataDir!
@redoDataDir mkdirp
$"{@redoDataDir}/redo.sqlite3" redoDb!
@redoDb $REDO_DB!
ensureDb

args cliArgs!
@cliArgs len 0 = if
    "error" "missing target" msg
end

@cliArgs 0 nth firstArg!
@firstArg isHelpArg if
    printHelp
else
    @firstArg "root" =
if
    @cliArgs len 2 < if
        "error" "usage: redo.msh root /path/to/a/project/root|list|remove /path/to/a/project/root" msg
    end
    @cliArgs 1 nth isHelpArg if
        printHelp
    else
    @cliArgs 1 nth secondArg!
    @secondArg "list" = if
        @cliArgs len 2 != if
            "error" "usage: redo.msh root list" msg
        end
        listProjectRoots
    else
        @secondArg "remove" = if
            @cliArgs len 3 != if
                "error" "usage: redo.msh root remove /path/to/a/project/root" msg
            end
            @cliArgs 2 nth isHelpArg if
                printHelp
            else
                @cliArgs 2 nth removeProjectRoot
            end
        else
            @cliArgs len 2 != if
                "error" "usage: redo.msh root /path/to/a/project/root" msg
            end
            @secondArg registerProjectRoot
        end
    end
    end
else
    `.` absPath str currentDir!
    @currentDir findProjectRoot foundProjectRoot! projectRoot!
    @foundProjectRoot not if
        @currentDir candidateProjectRoots promptForProjectRoot selectedRootSet! selectedRoot!
        @selectedRootSet if
            @selectedRoot registerProjectRoot
            @selectedRoot projectRoot!
        else
            "error" $"No project root found for {@currentDir}. Add one with: redo.msh root {@currentDir}" msg
        end
    end

    @projectRoot $REDO_BASE!
    @currentDir $REDO_STARTDIR!
    "1" $REDO_TOPLEVEL!
    @projectRoot cd
    ['redo-ifchange.msh' args]!
end
end
