#!/usr/bin/env mshell

def msg (str str --)
    message! level!
    @level "info" startsWith if
        "" level!
    end
    $"redo-ifchange: {@level} {@message}" wle
    @level "error" startsWith if
        111 exit
    end
end

def printHelp ( -- )
    "Usage: redo-ifchange.msh [-d] TARGET..." wl
    "" wl
    "Options:" wl
    "  -d           Enable debug logging" wl
    "  -h, --help   Show this help text" wl
end

def isHelpArg (str -- bool)
    arg!
    @arg "-h" = or. (@arg "--help" =) end
end

def dbDataDir ( -- str)
    $LOCALAPPDATA?
    if
        $"{$LOCALAPPDATA}/redo-msh"
    else
        $XDG_DATA_HOME?
        if
            $"{$XDG_DATA_HOME}/redo-msh"
        else
            $"{$HOME}/.local/share/redo-msh"
        end
    end
end

def sqlQuote (str -- str)
    value!
    @value "'" "''" findReplace escaped!
    "'" @escaped + "'" +
end

def dbPath ( -- str)
    $REDO_DB
end

def baseSql ( -- str)
    $REDO_BASE sqlQuote
end

def absoluteFrom (str str -- str)
    startDir! raw!
    `.` absPath str oldDir!
    @startDir cd
    @raw absPath str absoluteTarget!
    @oldDir cd
    @absoluteTarget
end

def relativeFromRoot (str str -- str bool)
    root! absoluteTarget!
    @absoluteTarget toPath @root toPath =
    if
        "" true
    else
        @absoluteTarget dirname str parent!
        @absoluteTarget toPath @parent toPath =
        if
            "" false
        else
            @parent @root relativeFromRoot foundRelative! relativeParent!
            @foundRelative
            if
                @absoluteTarget basename str segment!
                @relativeParent len 0 =
                if
                    @segment true
                else
                    $"{@relativeParent}/{@segment}" true
                end
            else
                "" false
            end
        end
    end
end

def canonicalizeTarget (str -- str)
    rawTarget!
    @rawTarget $REDO_STARTDIR absoluteFrom absoluteTarget!
    @absoluteTarget $REDO_BASE relativeFromRoot foundRelative! relativeTarget!
    @foundRelative not if
        "error" $"Target {@rawTarget} resolves outside project root {$REDO_BASE}" msg
    end
    @relativeTarget len 0 = if
        "error" $"Target {@rawTarget} resolves to the project root, which is not a valid build target" msg
    end
    @relativeTarget
end

def sqlExec (str --)
    sql!
    ['sqlite3' '-batch' dbPath @sql] ? rc!
    @rc 0 != if
        "error" $"sqlite3 failed with exit code {@rc}" msg
    end
end

def sqlRead (str -- str)
    ['sqlite3' '-batch' '-noheader' dbPath] swap append oc;
end

def sqlLines (str -- [str])
    sqlRead out!
    @out trim trimmed!
    @trimmed len 0 = if
        []
    else
        @out lines
    end
end

def ensureDb ( --)
    "CREATE TABLE IF NOT EXISTS Schema (version TEXT NOT NULL PRIMARY KEY);"
    sqlExec
    "CREATE TABLE IF NOT EXISTS Files (base TEXT NOT NULL, name TEXT NOT NULL, type TEXT, md5 TEXT, uptodate TEXT, result TEXT, PRIMARY KEY (base, name));"
    sqlExec
    "CREATE TABLE IF NOT EXISTS Deps (base TEXT NOT NULL, target TEXT NOT NULL, source TEXT NOT NULL, kind TEXT NOT NULL, phase TEXT NOT NULL, PRIMARY KEY (base, target, source, kind, phase));"
    sqlExec
    "CREATE TABLE IF NOT EXISTS ProjectRoots (root TEXT NOT NULL PRIMARY KEY);"
    sqlExec
    "SELECT version FROM Schema LIMIT 1;" sqlRead trim schemaVersion!
    @schemaVersion len 0 = if
        "INSERT INTO Schema (version) VALUES ('1');" sqlExec
        "1" schemaVersion!
    end
    @schemaVersion "1" != if
        "error" $"Unsupported schema version '{@schemaVersion}' in {$REDO_DB}" msg
    end
end

def resetRunState ( --)
    baseSql baseSqlValue!
    $"UPDATE Files SET uptodate = NULL, type = NULL WHERE base = {@baseSqlValue};" sqlExec
    $"DELETE FROM Deps WHERE base = {@baseSqlValue} AND phase = 'build';" sqlExec
end

def ensureFileRow (str --)
    target!
    baseSql baseSqlValue!
    @target sqlQuote targetSql!
    $"INSERT OR IGNORE INTO Files (base, name) VALUES ({@baseSqlValue}, {@targetSql});" sqlExec
end

def fileValue (str str -- str)
    column! target!
    baseSql baseSqlValue!
    @target sqlQuote targetSql!
    $"SELECT COALESCE({@column}, '') FROM Files WHERE base = {@baseSqlValue} AND name = {@targetSql};" sqlRead trim
end

def setFileValue (str str str --)
    value! column! target!
    @target ensureFileRow
    baseSql baseSqlValue!
    @target sqlQuote targetSql!
    @value sqlQuote valueSql!
    $"UPDATE Files SET {@column} = {@valueSql} WHERE base = {@baseSqlValue} AND name = {@targetSql};" sqlExec
end

def clearBuildDeps (str --)
    target!
    baseSql baseSqlValue!
    @target sqlQuote targetSql!
    $"DELETE FROM Deps WHERE base = {@baseSqlValue} AND target = {@targetSql} AND phase = 'build';" sqlExec
end

def clearStableDeps (str --)
    target!
    baseSql baseSqlValue!
    @target sqlQuote targetSql!
    $"DELETE FROM Deps WHERE base = {@baseSqlValue} AND target = {@targetSql} AND phase = 'stable';" sqlExec
end

def stableDeps (str str -- [str])
    kind! target!
    baseSql baseSqlValue!
    @target sqlQuote targetSql!
    @kind sqlQuote kindSql!
    $"SELECT source FROM Deps WHERE base = {@baseSqlValue} AND target = {@targetSql} AND kind = {@kindSql} AND phase = 'stable' ORDER BY source;" sqlLines
end

def hasDep (str str str -- bool)
    phase! kind! target!
    baseSql baseSqlValue!
    @target sqlQuote targetSql!
    @kind sqlQuote kindSql!
    @phase sqlQuote phaseSql!
    $"SELECT COUNT(*) FROM Deps WHERE base = {@baseSqlValue} AND target = {@targetSql} AND kind = {@kindSql} AND phase = {@phaseSql};" sqlRead trim count!
    @count "0" !=
end

def recordDep (str str str str --)
    phase! kind! target!
    source!
    baseSql baseSqlValue!
    @target sqlQuote targetSql!
    @source sqlQuote sourceSql!
    @kind sqlQuote kindSql!
    @phase sqlQuote phaseSql!
    $"INSERT OR IGNORE INTO Deps (base, target, source, kind, phase) VALUES ({@baseSqlValue}, {@targetSql}, {@sourceSql}, {@kindSql}, {@phaseSql});" sqlExec
end

def finalizeDeps (str --)
    target!
    @target clearStableDeps
    baseSql baseSqlValue!
    @target sqlQuote targetSql!
    $"INSERT OR IGNORE INTO Deps (base, target, source, kind, phase) SELECT base, target, source, kind, 'stable' FROM Deps WHERE base = {@baseSqlValue} AND target = {@targetSql} AND phase = 'build';" sqlExec
    @target clearBuildDeps
end

def findDoFile (str -- str)
  target!
  $"{@target}.do" isFile
  if
      $"{@target}.do" just
  else
      none doFile!
      @target dirname absPath dir!
      @target basename getTestFiles files!
      @files
      (
        f! @dir @f tryAllParentDirs result!
        @result isNone if
            false
        else
            @result doFile! true
        end
      ) eachWhile
      @doFile
  end
end

def getTestFiles (str -- )
    "." split splitTarget!
    @splitTarget len seq (1 +) map
    ( i! ["default"] @splitTarget @i skip extend "." join ".do" + )
    map
end

def tryAllParentDirs ( -- )
    file! startDir!
    @startDir toPath @file toPath / testFile!
    @testFile isFile
    if
        @testFile just
    else
        @startDir dirname newDir!
        @startDir toPath @newDir toPath =
        if
            none
        else
            @newDir @file tryAllParentDirs
        end
    end
end

def recordPrereq (str str --)
    redoparent! prereq!
    @redoparent '' != if
        @prereq @redoparent "normal" "build" recordDep
    end
end

def runRedoIfchange (str str -- bool)
    parent! child!
    @child @parent $REDOPARENT! $REDO_BASE $REDO_BASE! $REDO_DB $REDO_DB! $REDO_BASE $REDO_STARTDIR! "" $REDO_TOPLEVEL! ['redo-ifchange.msh' @child] ? rc!
    @rc 0 =
end

def checkNormalDeps ([str] str bool -- bool)
    debug! target! deps!
    @deps len 0 = if
        true
    else
        @deps 0 nth line!
        @line @target runRedoIfchange
        not if
            "error" $"{@target}: failed to build prerequisite {@line}" msg
        end

        @line "uptodate" fileValue uptodateRead!
        @uptodateRead len 0 = if
            "ASSERT" $"{@target}: no uptodate state for {@line}" msg
        end
        @debug if
            $"Prerequisite {@line} is up to date = {@uptodateRead}.." wle
        end

        @uptodateRead "n" =
        if
            false
        else
            @deps 1: @target @debug checkNormalDeps
        end
    end
end

def checkMissingDeps ([str] -- bool)
    deps!
    @deps len 0 = if
        true
    else
        @deps 0 nth line!
        @line isFile
        if
            false
        else
            @deps 1: checkMissingDeps
        end
    end
end

def handleTarget (str str bool --)
    debug! redoParent! target!
    @debug if
        $"Starting processing target {@target}.." wle
    end

    @target "uptodate" fileValue cachedUptodate!
    @cachedUptodate len 0 > if
        @target @redoParent recordPrereq
    else
        @target clearBuildDeps

        @target "type" fileValue type!
        @type len 0 = if
            @target findDoFile isNone if
                @target isFile if
                    "s" type!
                else
                    @redoParent '' = if
                        "error" $"No such target and no build script found for {@target}" msg
                    else
                        "s" type!
                    end
                end
            else
                "t" type!
            end
            @target "type" @type setFileValue
        end

        @debug if
            $"Determined {@target} file type = '{@type}'.." wle
        end

        "n" uptodate!
        @type "s" =
        if
            @target isFile if
                @target toPath md5 newmd5!
                @target "md5" fileValue oldmd5!
                @oldmd5 len 0 > if
                    @newmd5 @oldmd5 = if
                        "y" uptodate!
                    end
                end
                @target "md5" @newmd5 setFileValue
            end

            @debug if
                $"{@target} is a source file, determined up to date = {@uptodate}.." wle
            end
            @target "uptodate" @uptodate setFileValue
            @target @redoParent recordPrereq
        else
            "y" uptodate!
            @target isFile
            if
                @target "normal" stableDeps @target @debug checkNormalDeps
                not if
                    "n" uptodate!
                end

                @uptodate "n" != if
                    @target "nonexist" stableDeps checkMissingDeps
                    not if
                        "n" uptodate!
                    end
                end

                @uptodate "n" != if
                    @target "always" "stable" hasDep if
                        "n" uptodate!
                    end
                end
            else
                "n" uptodate!
            end

            @debug if
                $"Checked prerequisites for {@target}, determined up to date = {@uptodate}.." wle
            end

            @uptodate "n" = if
                @target clearStableDeps

                @target findDoFile buildFile!
                @buildFile isNone if
                    "error" $"No build script found for target {@target}" msg
                end
                @buildFile ? buildFile!
                @buildFile @target runRedoIfchange
                not if
                    "error" $"{@target}: failed to build prerequisite {@buildFile}" msg
                end

                @target absPath str targetAbs!
                @targetAbs dirname str targetDir!
                @buildFile absPath str buildFileAbs!
                $"{@targetAbs}.tmpfile" outFile!
                $"{@targetAbs}.tmpfile.stdout" stdoutFile!

                @debug if
                    $"Executing build script {@buildFile} for target {@target}.." wle
                end
                `.` absPath str oldDir!
                @targetDir cd
                @target $REDOPARENT!
                $REDO_BASE $REDO_BASE!
                $REDO_DB $REDO_DB!
                @targetDir $REDO_STARTDIR!
                "" $REDO_TOPLEVEL!
                [msh
                    @buildFileAbs
                    @target
                    @target basename stem
                    @outFile
                ] @stdoutFile > ? result!
                @oldDir cd

                @outFile fileSize 0 maybe outfileSize!
                @stdoutFile fileSize 0 maybe stdoutSize!
                @outfileSize 0 > @stdoutSize 0 > and if
                    "info" $"{@buildFile} wrote to $3 and stdout" msg
                    255 result!
                end

                @target "result" @result str setFileValue
                @debug if
                    $"Build script {@buildFile} for target {@target} completed with result {@result}.." wle
                end

                @outfileSize 0 > if
                    @stdoutFile @outFile
                else
                    @outFile @stdoutFile
                end
                usedFile! nonUsedFile!

                @result
                if
                    @usedFile toPath md5 newmd5!
                    @target "md5" fileValue oldmd5!
                    @oldmd5 len 0 > if
                        @newmd5 @oldmd5 = if
                            "y" uptodate!
                        end
                    end

                    @target "always" "build" hasDep if
                        "n" uptodate!
                    end

                    @debug if
                        $"Moving {@usedFile} to {@target}.." wle
                    end
                    @usedFile @targetAbs mv
                    @target "md5" @newmd5 setFileValue
                    "info" $"rebuilt {@target}" msg
                    @nonUsedFile rmf
                else
                    @usedFile rmf
                    @nonUsedFile rmf
                    "error" $"failed to rebuild {@target}" msg
                end
            end

            @target finalizeDeps
            @target @redoParent recordPrereq
            @target "uptodate" @uptodate setFileValue
        end
    end

    @debug if
        $"Ending processing target {@target}.." wle
    end
end

def processTargets ([str] str bool --)
    debug! redoParent! targetsToProcess!
    @targetsToProcess len 0 > if
        @targetsToProcess 0 nth target!
        @targetsToProcess len 1 >
        if
            @debug
            if
                @target @redoParent $REDOPARENT! $REDO_BASE $REDO_BASE! $REDO_DB $REDO_DB! $REDO_BASE $REDO_STARTDIR! "" $REDO_TOPLEVEL! ['redo-ifchange.msh' '-d' @target] ? rc!
            else
                @target @redoParent $REDOPARENT! $REDO_BASE $REDO_BASE! $REDO_DB $REDO_DB! $REDO_BASE $REDO_STARTDIR! "" $REDO_TOPLEVEL! ['redo-ifchange.msh' @target] ? rc!
            end
            @rc 0 != if
                @rc exit
            end
        else
            @target @redoParent @debug handleTarget
        end
        @targetsToProcess 1: @redoParent @debug processTargets
    end
end

$REDO_BASE? if $REDO_BASE else `.` absPath end redoBase!
dbDataDir redoDataDir!
@redoDataDir mkdirp
$"{@redoDataDir}/redo.sqlite3" redoDb!
@redoBase $REDO_BASE!
@redoDb $REDO_DB!
@redoBase cd

ensureDb

args (isHelpArg) any if printHelp 0 exit end

$REDO_TOPLEVEL? ($REDO_TOPLEVEL "1" =) and if resetRunState end

$REDOPARENT? if $REDOPARENT else '' end thisParent!

false debug!
[] targets!

args args!
@args reverse
(
    @args pop arg!
    @arg isNone if
        break
    end
    @arg? "-d" =
    if
        true debug!
    else
        @arg? canonicalizeTarget @targets swap append drop
    end
) loop

@targets @thisParent @debug processTargets
